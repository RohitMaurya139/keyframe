# KEYFRAME server secrets — copy to `.env` and fill in. `.env` is gitignored.
# Rotate keys by editing `.env` only; no code or config.json changes needed.
#
# LLM provider chain (automatic fallback, defined in src/services/openrouter.js):
#   KIE Gemini (optional primary, if set) -> OpenRouter (primary -> secondary model)
# If a provider key is dead/exhausted, requests fall through to the next one.

# OpenRouter (primary provider). https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# KIE Gemini (optional primary). Leave blank to skip.
KIE_API_KEY=

# Stock media (images/video/SFX). MEDIA_PROVIDER moves that source to the front
# of the asset search order ("pixabay-api" is normalized to the "pixabay" provider).
MEDIA_PROVIDER=pixabay-api
PIXABAY_API_KEY=
FREESOUND_TOKEN=
